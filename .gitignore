# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test_artifacts/*
!/test_artifacts/test_*_preview.png
/test_local_preview.command

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/dist-static/
/.wrangler/
/outputs/
/work/
/.worktrees/

# Blender 与 Python 本地产物
*.blend1
__pycache__/
*.pyc

# 可再下载的原始高程栅格；派生的 JSON 数据保留在仓库中
/docs/research/data/*.tif
/docs/research/data/*.hgt.gz
